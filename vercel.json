{
  "version": 2,
  "builds": [
    { "src": "api/usuarios.js", "use": "@vercel/node" },
    { "src": "api/links.js", "use": "@vercel/node" },
    { "src": "api/logs.js", "use": "@vercel/node" },
    { "src": "api/avisos.js", "use": "@vercel/node" },
    { "src": "api/gemini.js", "use": "@vercel/node" },
    { "src": "api/avaliacoes.js", "use": "@vercel/node" },
    { "src": "api/fotos.js", "use": "@vercel/node" },
    { "src": "api/cmsp.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/usuarios", "dest": "/api/usuarios.js" },
    { "src": "/api/links", "dest": "/api/links.js" },
    { "src": "/api/logs", "dest": "/api/logs.js" },
    { "src": "/api/avisos", "dest": "/api/avisos.js" },
    { "src": "/api/gemini", "dest": "/api/gemini.js" },
    { "src": "/api/avaliacoes", "dest": "/api/avaliacoes.js" },
    { "src": "/api/fotos", "dest": "/api/fotos.js" },
    { "src": "/api/cmsp", "dest": "/api/cmsp.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}